# SIANCEK — Environment Variables
# ================================
# File ini berisi variabel lingkungan global untuk docker-compose.
# Variabel khusus Laravel ada di laravel-app/.env

# Versi rilis
APP_VERSION=1.0.0

# Kunci API untuk autentikasi antara Laravel <-> ML Service
ML_API_KEY=siancek-dev-key-please-change-me

# Database MySQL
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=siancek
MYSQL_USER=siancek
MYSQL_PASSWORD=siancek_secret

# Port mapping host
APP_PORT=8000
ML_PORT=8001
DB_PORT=3306
